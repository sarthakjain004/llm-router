# =============================================================================
# llm-router — environment template
# Copy to .env and fill in. .env is gitignored; NEVER commit real keys.
#   cp .env.example .env
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────
# The single key your agents present as their OpenAI api_key.
# Generate a strong one:  echo "sk-$(openssl rand -hex 32)"
LITELLM_MASTER_KEY=sk-CHANGE-ME

# ── Provider keys (one legitimate key per provider — no multi-account farming) ──
# Leave a key blank if you don't have that provider yet; its deployments fail fast
# and the router skips to the next fallback.
#
# ⚠ IMPORTANT: keep comments on their OWN lines. Do NOT put a "# ..." comment after
# a value on the same line — Docker's env_file reads the whole rest of the line
# (comment included) as the value, which breaks the key.

# https://aistudio.google.com/apikey  (free tier; free-tier prompts may be used for training)
GEMINI_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=
# https://cloud.cerebras.ai  (NOTE: now requires adding a payment method to activate — no longer no-card free)
CEREBRAS_API_KEY=
# https://openrouter.ai/keys  (strictly $0 tier: 20 RPM / 50 requests-per-day)
OPENROUTER_API_KEY=
# https://build.nvidia.com  (key looks like nvapi-... ; finite ~1000-credit pool, non-renewing)
NVIDIA_NIM_API_KEY=
# NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1/   (default; only for a self-hosted NIM)

# Added free providers (ADR-0009) — all blank by default; each deployment stays
# dormant until you fill its key.
# https://github.com/settings/tokens  -- a PAT with "models" read; GitHub Models (15 RPM / 150 req-day, no card)
GITHUB_API_KEY=
# https://dash.cloudflare.com/profile/api-tokens  -- Workers AI token (10,000 neurons/day, no card)
CLOUDFLARE_API_KEY=
# https://dash.cloudflare.com  -- REQUIRED alongside CLOUDFLARE_API_KEY (LiteLLM reads it from env)
CLOUDFLARE_ACCOUNT_ID=
# https://z.ai  -- Z.AI/Zhipu GLM free flash tier (no card)
ZAI_API_KEY=
# https://dashboard.cohere.com/api-keys  -- trial key (20 RPM / ~1000 req-MONTH)
COHERE_API_KEY=

# ── Network binding ─────────────────────────────────────────────────────────
# Local Mac: 127.0.0.1 (reach the proxy via an SSH tunnel).
# Oracle VM: set to the box's Tailscale IP (100.x.y.z) so port 4000 is reachable
# ONLY over the tailnet and never on the public interface.
# IMPORTANT: docker-published ports bypass ufw, so this bind address IS the firewall.
BIND_ADDR=127.0.0.1

# ── Image pin ───────────────────────────────────────────────────────────────
# main-stable is being retired (~Sept 2026). Pin an explicit tag.
# v1.92.0 is the latest stable line (July 2026) and is multi-arch incl. linux/arm64.
# Check for newer stable tags: https://github.com/BerriAI/litellm/releases
LITELLM_TAG=v1.92.0

# ── OpenTelemetry (optional; OFF by default) ────────────────────────────────
# When true, the entrypoint uncomments the `callbacks: ["otel"]` line in config.yaml.
OTEL_ENABLED=false
# OTEL_EXPORTER=otlp_http                                  # otlp_http (OpenLIT/Tempo/Jaeger) or otlp_grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-openlit-host:4318
# OTEL_EXPORTER_OTLP_HEADERS=                              # e.g. "api-key=..."

# ── Postgres spend/key logging via Neon (optional; OFF by default) ──────────
# IMPORTANT: to DISABLE, leave this line COMMENTED OUT. Do NOT set it to an
# empty string ("DATABASE_URL=") — an empty value still triggers Prisma
# migrations at boot and the container will crash-loop.
# DATABASE_URL=postgresql://USER:PASS@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# STORE_MODEL_IN_DB=True     # only if you later want to add models at runtime via the admin API

# ── Ollama local fallback (SKIPPED by default; see commented stubs) ─────────
# Enable the ollama service in docker-compose.yml and the ollama-local entry in
# config.yaml, then set this to the reachable base URL.
# OLLAMA_API_BASE=http://ollama:11434
